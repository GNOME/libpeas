#, c-format
msgid "Dependency “%s” was not found"
msgstr "Medhelweyth serghek “%s” nyns o kevys"

#: libpeas/peas-engine.c:1136
#, c-format
msgid "Dependency “%s” failed to load"
msgstr "Medhelweyth serghek “%s” fyllis dhe garga"

#: libpeas/peas-engine.c:1150
#, c-format
msgid "Plugin loader “%s” was not found"
msgstr "Kargell ystynnans “%s” nyns o kevys"

#: libpeas/peas-engine.c:1162
#, c-format
msgid "Failed to load"
msgstr "Ny yllir karga"
